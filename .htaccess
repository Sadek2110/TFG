# Si el DocumentRoot apunta a la raíz del proyecto en lugar de a public/,
# redirigimos todas las peticiones al front controller dentro de public/.

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
