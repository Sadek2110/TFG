# Permitir sólo imágenes; cualquier otro archivo se bloquea aunque esté
# dentro del directorio público. PHP no se ejecuta nunca desde aquí.
<FilesMatch "\.(php|phtml|phar|html|htm|sh|exe|bat|cmd|sql|env|log|ini|json|yml|yaml|md)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

<IfModule mod_php.c>
    php_flag engine off
</IfModule>
Options -ExecCGI
AddType text/plain .php .phtml .phar .sh
